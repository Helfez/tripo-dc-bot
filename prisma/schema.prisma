generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-arm64-openssl-3.0.x", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           Int      @id @default(autoincrement())
  discordId    String   @unique @map("discord_id")
  username     String   @default("")
  drawChances  Int      @default(0) @map("draw_chances")
  totalDraws   Int      @default(0) @map("total_draws")
  dailyDraws   Int      @default(0) @map("daily_draws")
  dailyEarned  Int      @default(0) @map("daily_earned")
  lastDrawDate String?  @map("last_draw_date")
  hasPurchased Boolean  @default(false) @map("has_purchased")
  joinedAt     DateTime @default(now()) @map("joined_at")
  createdAt    DateTime @default(now()) @map("created_at")

  works    Work[]
  prizes   Prize[]
  referralsMade     Referral[] @relation("Referrer")
  referralsReceived Referral[] @relation("Invited")

  @@map("users")
}

model Work {
  id        Int      @id @default(autoincrement())
  workUid   String   @unique @map("work_uid")
  userId    Int      @map("user_id")
  discordId String   @map("discord_id")
  mode      String   // 'jujumon' | 'jujutrainers'
  prompt    String   @default("")
  imageUrl  String   @default("") @map("image_url")
  shareUrl  String   @default("") @map("share_url")
  viewCount Int      @default(0) @map("view_count")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id])

  @@map("works")
}

model Prize {
  id         Int      @id @default(autoincrement())
  userId     Int      @map("user_id")
  discordId  String   @map("discord_id")
  prizeTier  String   @map("prize_tier")  // 'first','second','third','discount_90','discount_80','discount_70'
  prizeName  String   @map("prize_name")
  couponCode String   @unique @map("coupon_code")
  isCopied   Boolean  @default(false) @map("is_copied")
  isUsed     Boolean  @default(false) @map("is_used")
  expiresAt  DateTime? @map("expires_at")
  createdAt  DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id])

  @@map("prizes")
}

model DailyPrizePool {
  id         Int    @id @default(autoincrement())
  prizeDate  String @map("prize_date")   // YYYY-MM-DD
  prizeTier  String @map("prize_tier")
  totalCount Int    @map("total_count")
  wonCount   Int    @default(0) @map("won_count")
  remaining  Int
  createdAt  DateTime @default(now()) @map("created_at")

  @@unique([prizeDate, prizeTier])
  @@map("daily_prize_pool")
}

model Referral {
  id         Int      @id @default(autoincrement())
  referrerId Int      @map("referrer_id")
  invitedId  Int      @map("invited_id")
  status     String   @default("pending") // 'pending','confirmed','invalid'
  createdAt  DateTime @default(now()) @map("created_at")

  referrer User @relation("Referrer", fields: [referrerId], references: [id])
  invited  User @relation("Invited", fields: [invitedId], references: [id])

  @@map("referrals")
}

model Config {
  key       String   @id
  value     String
  updatedAt DateTime @default(now()) @map("updated_at")

  @@map("config")
}

// ---- Image Pool ----

model PoolImage {
  id        Int      @id @default(autoincrement())
  name      String   @default("")
  s3Key     String   @map("s3_key")
  url       String   @default("")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("pool_images")
}

// ---- Test Platform Models ----

model TestCase {
  id        Int      @id @default(autoincrement())
  name      String
  prompt    String   @default("")
  imagePath String   @default("") @map("image_path")
  remark    String   @default("")
  createdAt DateTime @default(now()) @map("created_at")

  results   TestResult[]

  @@map("test_cases")
}

model TestTask {
  id             Int       @id @default(autoincrement())
  workflowId     String    @map("workflow_id")
  workflowName   String    @map("workflow_name")
  status         String    @default("pending")
  totalCases     Int       @default(0) @map("total_cases")
  completedCases Int       @default(0) @map("completed_cases")
  failedCases    Int       @default(0) @map("failed_cases")
  remark         String    @default("")
  review         String    @default("none")
  reviewNote     String    @default("") @map("review_note")
  createdAt      DateTime  @default(now()) @map("created_at")
  finishedAt     DateTime? @map("finished_at")

  results        TestResult[]

  @@map("test_tasks")
}

model TestResult {
  id              Int      @id @default(autoincrement())
  taskId          Int      @map("task_id")
  caseId          Int      @map("case_id")
  status          String   @default("pending")
  resultImagePath String   @default("") @map("result_image_path")
  error           String   @default("")
  durationMs      Int      @default(0) @map("duration_ms")
  review          String   @default("none")
  aiReview        String   @default("none") @map("ai_review")
  aiReason        String   @default("") @map("ai_reason")
  createdAt       DateTime @default(now()) @map("created_at")

  task   TestTask @relation(fields: [taskId], references: [id])
  case   TestCase @relation(fields: [caseId], references: [id])

  @@map("test_results")
}

// ---- Tripo 3D Generation ----

model TripoTask {
  id              Int       @id @default(autoincrement())
  name            String    @default("")
  inputImagePath  String    @default("") @map("input_image_path")
  tripoTaskId     String    @default("") @map("tripo_task_id")
  status          String    @default("pending")
  progress        Int       @default(0)
  faceLimit       Int       @default(200000) @map("face_limit")
  modelVersion    String    @default("v2.0-20240919") @map("model_version")
  textureQuality  String    @default("standard") @map("texture_quality")
  texture         Boolean   @default(false)
  pbr             Boolean   @default(false)
  modelUrl        String    @default("") @map("model_url")
  renderedImage   String    @default("") @map("rendered_image")
  renderedVideo   String    @default("") @map("rendered_video")
  shareUrl        String    @default("") @map("share_url")
  error           String    @default("")
  durationMs      Int       @default(0) @map("duration_ms")
  createdAt       DateTime  @default(now()) @map("created_at")
  finishedAt      DateTime? @map("finished_at")

  @@map("tripo_tasks")
}
